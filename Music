local function createLoadingScreen()
    if loadingFrame then
        loadingFrame:Destroy()
    end

    loadingFrame = Instance.new("Frame")
    loadingFrame.Size = UDim2.new(1, 0, 1, 0)
    loadingFrame.Position = UDim2.new(0, 0, 0, 0)
    loadingFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    loadingFrame.BackgroundTransparency = 0.3
    loadingFrame.BorderSizePixel = 0
    loadingFrame.ZIndex = 1000
    loadingFrame.Parent = screenGui

    local loadingContainer = Instance.new("Frame")
    loadingContainer.Size = UDim2.new(0, 300, 0, 200)
    loadingContainer.Position = UDim2.new(0.5, -150, 0.5, -100)
    loadingContainer.BackgroundColor3 = colors.primary
    loadingContainer.BorderSizePixel = 0
    loadingContainer.Parent = loadingFrame

    local containerCorner = Instance.new("UICorner")
    containerCorner.CornerRadius = UDim.new(0, 16)
    containerCorner.Parent = loadingContainer

    -- Animated music note icon
    local musicNoteIcon = Instance.new("TextLabel")
    musicNoteIcon.Size = UDim2.new(0, 80, 0, 80)
    musicNoteIcon.Position = UDim2.new(0.5, -40, 0, 25)
    musicNoteIcon.BackgroundTransparency = 1
    musicNoteIcon.Text = "🎵"
    musicNoteIcon.TextColor3 = colors.loadingAccent
    musicNoteIcon.TextSize = 60
    musicNoteIcon.Font = Enum.Font.GothamBold
    musicNoteIcon.Parent = loadingContainer

    -- Loading text
    local loadingText = Instance.new("TextLabel")
    loadingText.Size = UDim2.new(1, -40, 0, 30)
    loadingText.Position = UDim2.new(0, 20, 0, 110)
    loadingText.BackgroundTransparency = 1
    loadingText.Text = "Đang tải nhạc..."
    loadingText.TextColor3 = colors.text
    loadingText.TextSize = 16
    loadingText.Font = Enum.Font.GothamBold
    loadingText.Parent = loadingContainer

    -- Spinning circle loader
    local spinnerFrame = Instance.new("Frame")
    spinnerFrame.Size = UDim2.new(0, 50, 0, 50)
    spinnerFrame.Position = UDim2.new(0.5, -25, 0, 145)
    spinnerFrame.BackgroundTransparency = 1
    spinnerFrame.Parent = loadingContainer

    -- Create 8 dots for spinner
    local spinnerDots = {}
    for i = 1, 8 do
        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 8, 0, 8)
        dot.BackgroundColor3 = colors.loadingAccent
        dot.BorderSizePixel = 0
        dot.AnchorPoint = Vector2.new(0.5, 0.5)
        
        local angle = (i - 1) * (math.pi * 2 / 8)
        local radius = 18
        dot.Position = UDim2.new(
            0.5, math.cos(angle) * radius,
            0.5, math.sin(angle) * radius
        )
        
        dot.Parent = spinnerFrame
        
        local dotCorner = Instance.new("UICorner")
        dotCorner.CornerRadius = UDim.new(1, 0)
        dotCorner.Parent = dot
        
        table.insert(spinnerDots, dot)
    end

    -- Animate music note bounce
    spawn(function()
        while loadingFrame and loadingFrame.Parent do
            TweenService:Create(musicNoteIcon, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), 
                {Position = UDim2.new(0.5, -40, 0, 20)}):Play()
            wait(0.5)
            TweenService:Create(musicNoteIcon, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), 
                {Position = UDim2.new(0.5, -40, 0, 30)}):Play()
            wait(0.5)
        end
    end)

    -- Animate loading text dots
    spawn(function()
        local dots = 0
        while loadingFrame and loadingFrame.Parent do
            dots = (dots % 3) + 1
            loadingText.Text = "Đang tải nhạc" .. string.rep(".", dots)
            wait(0.4)
        end
    end)

    -- Animate spinner rotation
    if loadingSpinnerConnection then
        loadingSpinnerConnection:Disconnect()
    end

    local time = 0
    loadingSpinnerConnection = RunService.RenderStepped:Connect(function(dt)
        time = time + dt * 3
        
        for i, dot in ipairs(spinnerDots) do
            local delay = (i - 1) * 0.125
            local opacity = (math.sin(time + delay * math.pi * 2) + 1) / 2
            dot.BackgroundTransparency = 1 - opacity
            
            local scale = 0.7 + opacity * 0.3
            dot.Size = UDim2.new(0, 8 * scale, 0, 8 * scale)
        end
    end)

    return loadingFrame
end

local function hideLoadingScreen()
    if loadingSpinnerConnection then
        loadingSpinnerConnection:Disconnect()
        loadingSpinnerConnection = nil
    end

    if loadingFrame then
        local fadeOut = TweenService:Create(loadingFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1})
        fadeOut:Play()
        fadeOut.Completed:Connect(function()
            loadingFrame:Destroy()
            loadingFrame = nil
        end)
    end
end

