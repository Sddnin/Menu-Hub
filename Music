    openBoxBtn.Text = "🎁 ĐANG MỞ... 🎁"
    openBoxBtn.BackgroundColor3 = colors.textSecondary

    spawn(function()
        for i = 1, 6 do
            wait(0.2)
            if i % 2 == 0 then
                mysteryIcon.Text = "📦"
                mysteryIcon.Rotation = 15
            else
