local function formatTime(seconds)
    if seconds <= 0 then return "0:00" end
    local mins = math.floor(seconds / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%d:%02d", mins, secs)
end

local function startProgressUpdate()
    if progressConnection then
        progressConnection:Disconnect()
    end

    progressConnection = RunService.Heartbeat:Connect(function()
        if currentSound and currentSound.IsPlaying then
            local timePos = currentSound.TimePosition
            local timeLen = currentSound.TimeLength

            if timeLen > 0 then
                local progress = timePos / timeLen
                progressBarFill.Size = UDim2.new(progress, 0, 1, 0)
                currentTimeLabel.Text = formatTime(timePos)
                totalTimeLabel.Text = formatTime(timeLen)
            end
        end
    end)
end

