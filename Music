local function playNextSong()
    if userData.shuffleMode then
        if #shuffleQueue > 0 then
            local nextSong = table.remove(shuffleQueue, 1)
            playMusic(nextSong)
            if #shuffleQueue == 0 then generateShuffleQueue() end
        end
    elseif currentPlaying then
        local currentIndex = 1
        for i, song in ipairs(filteredMusic) do
            if song.id == currentPlaying.id then
                currentIndex = i
                break
            end
        end

        local nextIndex = currentIndex + 1
        if nextIndex > #filteredMusic then
            nextIndex = 1
        end

        if filteredMusic[nextIndex] then
            playMusic(filteredMusic[nextIndex])
        end
    end
end

local function playPreviousSong()
    if currentPlaying then
        local currentIndex = 1
        for i, song in ipairs(filteredMusic) do
            if song.id == currentPlaying.id then
                currentIndex = i
                break
            end
        end

        local prevIndex = currentIndex - 1
        if prevIndex < 1 then
            prevIndex = #filteredMusic
        end

        if filteredMusic[prevIndex] then
            playMusic(filteredMusic[prevIndex])
        end
    end
end

