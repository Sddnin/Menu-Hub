local function createSound(musicId)
    if currentSound then
        pcall(function()
            currentSound:Stop()
            currentSound:Destroy()
        end)
        currentSound = nil
        wait(0.1)
    end

    local success, sound = pcall(function()
        local newSound = Instance.new("Sound")
        newSound.SoundId = "rbxassetid://" .. tostring(musicId)
        newSound.Volume = userData.volume
        newSound.Looped = userData.repeatMode == "one"
        newSound.Parent = workspace
        return newSound
    end)

    if success then
        return sound
    else
        return nil
    end
end

local function addToHistory(musicData)
    for i, item in ipairs(userData.history) do
        if item.id == musicData.id then
            table.remove(userData.history, i)
            break
        end
    end

    table.insert(userData.history, 1, {
        name = musicData.name,
        id = musicData.id,
        playTime = os.time()
    })

    if #userData.history > 20 then
        table.remove(userData.history, 21)
    end

    updateHistoryTab()
end

function playMusic(musicData)
    -- 🆕 Show loading screen
    createLoadingScreen()
    
    stopVisualizer()
    stopProgressUpdate()
    stopMiniProgressUpdate()

    spawn(function()
        -- Simulate network delay
        wait(0.5)
        
        currentSound = createSound(musicData.id)

        if not currentSound then
            hideLoadingScreen()
            showNotification("Lỗi tạo âm thanh! ID không hợp lệ.", colors.danger, "⚠️")
            return
        end

        -- Wait for sound to load
        local loadTimeout = 0
        while currentSound.TimeLength == 0 and loadTimeout < 5 do
            wait(0.1)
            loadTimeout = loadTimeout + 0.1
        end

        local success = pcall(function()
            currentSound:Play()
        end)

        -- 🆕 Hide loading screen
        hideLoadingScreen()

        if not success then
            showNotification("Lỗi phát nhạc! Thử lại sau.", colors.danger, "⚠️")
            return
        end

        currentPlaying = musicData
        nowPlayingLabel.Text = musicData.name
        statusLabel.Text = "Đang phát - Volume: " .. userData.volume
        musicIcon.Text = "🎵"

        minimizedSongLabel.Text = musicData.name
        minimizedPlayPauseBtn.Text = "⏸️"

        addToHistory(musicData)
        showNotification("🎵 Đang phát: " .. musicData.name, colors.accent, "🎵")

        startVisualizer()
        startProgressUpdate()
        startMiniProgressUpdate()

        if currentSound then
            currentSound.Ended:Connect(function()
                if userData.repeatMode == "all" or userData.shuffleMode then
                    playNextSong()
                elseif userData.repeatMode == "one" then
                    playMusic(musicData)
                else
                    stopMusic()
                end
            end)
        end
    end)
end

local function stopMusic()
    if currentSound then
        pcall(function()
            currentSound:Stop()
            currentSound:Destroy()
        end)
        currentSound = nil
    end

    stopVisualizer()
    stopProgressUpdate()
    stopMiniProgressUpdate()
    hideLoadingScreen()

    currentPlaying = nil
    nowPlayingLabel.Text = "Không có nhạc nào đang phát"
    statusLabel.Text = "Volume: " .. userData.volume .. " | Sẵn sàng phát nhạc"
    musicIcon.Text = "⏸️"

    minimizedSongLabel.Text = "Không có nhạc"
    minimizedPlayPauseBtn.Text = "▶️"

    showNotification("Đã dừng phát nhạc", colors.danger, "⏹️")
end

local function updateVolume(newVolume)
    newVolume = math.clamp(newVolume, 0, 10)
    userData.volume = newVolume
    volumeSlider.Text = tostring(newVolume)

    if newVolume == 0 then
        volumeIcon.Text = "🔇"
    elseif newVolume <= 3 then
        volumeIcon.Text = "🔉"
    else
        volumeIcon.Text = "🔊"
    end

    if currentSound then
        currentSound.Volume = newVolume
    end

    if currentPlaying then
        statusLabel.Text = "Đang phát - Volume: " .. newVolume
    else
        statusLabel.Text = "Volume: " .. newVolume .. " | Sẵn sàng phát nhạc"
    end

    showNotification("Volume: " .. newVolume .. "/10", colors.accent, volumeIcon.Text)
end

local function cycleRepeatMode()
    if userData.repeatMode == "off" then
        userData.repeatMode = "one"
        repeatBtn.Text = "🔂"
        repeatBtn.TextColor3 = colors.accent
        showNotification("Lặp lại: Một bài", colors.accent, "🔂")
    elseif userData.repeatMode == "one" then
        userData.repeatMode = "all"
        repeatBtn.Text = "🔁"
        repeatBtn.TextColor3 = colors.accent
        showNotification("Lặp lại: Tất cả", colors.accent, "🔁")
    else
        userData.repeatMode = "off"
        repeatBtn.Text = "🔄"
        repeatBtn.TextColor3 = colors.textSecondary
        showNotification("Tắt lặp lại", colors.textSecondary, "🔄")
    end

    if currentSound then
        currentSound.Looped = userData.repeatMode == "one"
    end
end

local function openRandomBox()
