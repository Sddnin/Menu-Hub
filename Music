local function filterMusic(searchText)
    filteredMusic = {}
    searchText = searchText:lower()

    if searchText == "" then
        filteredMusic = musicLibrary
    else
        for _, music in ipairs(musicLibrary) do
            if music.name:lower():find(searchText) or music.id:find(searchText) then
                table.insert(filteredMusic, music)
            end
        end
    end

    updateLibraryTab()
end

local function generateShuffleQueue()
    shuffleQueue = {}
    local tempLibrary = {}
    for _, song in ipairs(musicLibrary) do
        table.insert(tempLibrary, song)
    end
    for i = #tempLibrary, 2, -1 do
        local j = math.random(i)
        tempLibrary[i], tempLibrary[j] = tempLibrary[j], tempLibrary[i]
    end
    shuffleQueue = tempLibrary
end

local function toggleShuffle()
    userData.shuffleMode = not userData.shuffleMode
