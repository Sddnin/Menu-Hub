                mysteryIcon.Rotation = -15
            end
        end

        mysteryIcon.Rotation = 0
        mysteryIcon.Text = "✨"

        local randomSong = musicLibrary[math.random(1, #musicLibrary)]
        currentRandomSong = randomSong

        wait(0.5)
        playMusic(randomSong)

        spawn(function()
            local celebrations = {"🎉", "✨", "🎊", "🌟", "💫"}
