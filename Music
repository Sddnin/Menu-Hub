-- ===== DISK SPIN ANIMATION =====
local diskAngle = 0
local diskSpinConnection = nil

local function startDiskSpin()
    if diskSpinConnection then diskSpinConnection:Disconnect() end
    diskSpinConnection = RunService.RenderStepped:Connect(function(dt)
        if currentSound and currentSound.IsPlaying then
            diskAngle = diskAngle + dt * 120
            if diskAngle >= 360 then diskAngle = diskAngle - 360 end
            -- Simulate spin by cycling center color
            local pulse = math.sin(math.rad(diskAngle)) * 0.5 + 0.5
            diskCenter.BackgroundColor3 = Color3.fromRGB(
                200 + pulse * 30,
                150 - pulse * 30,
                80 + pulse * 20
            )
            -- Outer ring pulse
            diskRing.Color = Color3.fromRGB(
                150 + pulse * 80,
                150 + pulse * 80,
                150 + pulse * 80
            )
        else
            diskCenter.BackgroundColor3 = Color3.fromRGB(200, 150, 80)
            diskRing.Color = Color3.fromRGB(180, 180, 180)
        end
    end)
end
startDiskSpin()

