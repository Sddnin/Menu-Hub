                if tp.Character and tp.Character:FindFirstChild("HumanoidRootPart") and
                   char and char:FindFirstChild("HumanoidRootPart") then
                    local cf=char.HumanoidRootPart.CFrame
                    local lab=string.format("→%s (%d,%d,%d)",tp.Name,math.floor(cf.X),math.floor(cf.Y),math.floor(cf.Z))
                    table.insert(tpHistory,{label=lab,cframe=cf})
