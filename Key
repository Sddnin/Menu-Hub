makeToggle("ESP","👁","ESP",136,function(s)
    if espConn then espConn:Disconnect(); espConn=nil end
    if not s then
        for _,o in pairs(espObjs) do
            pcall(function() if o.hl then o.hl:Destroy() end; if o.bb then o.bb:Destroy() end end)
        end; espObjs={}; return
    end
    local function addESP(p)
        if p==lp then return end
        local function setup(c)
            local hrp = c:WaitForChild("HumanoidRootPart",3); if not hrp then return end
            local hl = Instance.new("Highlight"); hl.Adornee=c
            hl.FillColor=Color3.fromRGB(255,255,255); hl.FillTransparency=0.78
            hl.OutlineColor=Color3.fromRGB(255,255,255); hl.OutlineTransparency=0
            hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=c
            local bb = Instance.new("BillboardGui"); bb.Adornee=hrp
            bb.Size=UDim2.new(0,110,0,32); bb.StudsOffset=Vector3.new(0,3,0)
            bb.AlwaysOnTop=true; bb.ResetOnSpawn=false; bb.Parent=c
            local nl=Instance.new("TextLabel"); nl.Size=UDim2.new(1,0,0.55,0)
            nl.BackgroundTransparency=1; nl.Text=p.Name
            nl.TextColor3=Color3.fromRGB(255,255,255); nl.TextSize=12
            nl.TextStrokeTransparency=0.3; nl.Font=Enum.Font.GothamBold; nl.Parent=bb
            local dl=Instance.new("TextLabel"); dl.Size=UDim2.new(1,0,0.45,0)
            dl.Position=UDim2.new(0,0,0.55,0); dl.BackgroundTransparency=1
            dl.TextColor3=Color3.fromRGB(180,255,180); dl.TextSize=10
            dl.TextStrokeTransparency=0.3; dl.Font=Enum.Font.Gotham; dl.Parent=bb
            espObjs[p]={hl=hl,bb=bb,dl=dl}
        end
        if p.Character then setup(p.Character) end
        p.CharacterAdded:Connect(function(c) if toggleStates["ESP"] then setup(c) end end)
    end
    for _,p in pairs(Players:GetPlayers()) do addESP(p) end
    Players.PlayerAdded:Connect(function(p) if toggleStates["ESP"] then addESP(p) end end)
    espConn = Run.RenderStepped:Connect(function()
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local my = char.HumanoidRootPart.Position
        for p,o in pairs(espObjs) do
            if o.dl and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                o.dl.Text = math.floor((p.Character.HumanoidRootPart.Position-my).Magnitude).."m"
            end
        end
    end)
end)

