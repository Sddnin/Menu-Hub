local function updateScriptList(searchTerm)
    for _, child in pairs(scriptsContainer:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    searchTerm = searchTerm:lower()
    local row, col = 0, 0
    local totalHeight = 0

    for _, scriptData in ipairs(scriptsData) do
        if searchTerm == "" or scriptData.name:lower():find(searchTerm) then
            local position = UDim2.new(col * 0.52, 0, 0, row * 75)
            createScriptButton(scriptData, position)

            col = col + 1
            if col >= 2 then
                col = 0
                row = row + 1
            end
            totalHeight = (row + 1) * 75
        end
    end

    scriptContent.Size = UDim2.new(1, 0, 0, totalHeight + 50)
    contentArea.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight + 50, 300))
end

