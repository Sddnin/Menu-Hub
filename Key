-- ── iOS Toggle ─────────────────────────────────────────
local function makeToggle(id, icon, label, y, cb)
    local row = Instance.new("Frame")
    row.Name = id.."Row"; row.Size = UDim2.new(0.47,0,0,34)
    row.Position = UDim2.new(0,0,0,y); row.BackgroundColor3 = bg3()
    row.BorderSizePixel = 0; row.Parent = home; row.ZIndex = 52; corner(9,row)

    local il = Instance.new("TextLabel"); il.Size = UDim2.new(0,24,1,0)
    il.BackgroundTransparency=1; il.Text=icon; il.TextSize=14
    il.Font=Enum.Font.Gotham; il.Parent=row; il.ZIndex=53

    local tl = Instance.new("TextLabel"); tl.Size = UDim2.new(1,-70,1,0)
    tl.Position = UDim2.new(0,26,0,0); tl.BackgroundTransparency=1
    tl.Text=label; tl.TextColor3=tx2(); tl.TextSize=9
    tl.Font=Enum.Font.GothamSemibold; tl.TextXAlignment=Enum.TextXAlignment.Left
    tl.Parent=row; tl.ZIndex=53

    local track = Instance.new("Frame"); track.Name="Track"
    track.Size = UDim2.new(0,32,0,18); track.Position = UDim2.new(1,-36,0.5,-9)
    track.BackgroundColor3 = Color3.fromRGB(55,55,75); track.BorderSizePixel=0
    track.Parent=row; track.ZIndex=54; corner(9,track)

    local thumb = Instance.new("Frame"); thumb.Name="Thumb"
    thumb.Size = UDim2.new(0,13,0,13); thumb.Position = UDim2.new(0,2,0.5,-6.5)
    thumb.BackgroundColor3 = Color3.fromRGB(255,255,255); thumb.BorderSizePixel=0
    thumb.Parent=track; thumb.ZIndex=55; corner(7,thumb)

    local click = Instance.new("TextButton"); click.Size=UDim2.new(1,0,1,0)
    click.BackgroundTransparency=1; click.Text=""; click.AutoButtonColor=false
    click.Parent=row; click.ZIndex=56

    local on = false; toggleStates[id] = false

    local function set(state)
        on = state; toggleStates[id] = state
        tw(track, 0.2, {BackgroundColor3 = state and acc() or Color3.fromRGB(55,55,75)})
        tw(thumb, 0.2, {Position = state and UDim2.new(0,17,0.5,-6.5) or UDim2.new(0,2,0.5,-6.5)})
        tw(row,   0.15,{BackgroundColor3 = state and Color3.fromRGB(28,22,52) or bg3()})
        pcall(cb, state)
    end
    click.MouseButton1Click:Connect(function() set(not on) end)
    toggleSetters[id] = set
    return set
end

