-- Button Creation
local function createButton(name, text, position, callback, parent)
    parent = parent or homeContent

    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(0.31, -5, 0, 35)
    button.Position = position
    button.BackgroundColor3 = Color3.fromRGB(235, 235, 245)
    button.Text = text
    button.TextColor3 = Color3.fromRGB(80, 80, 100)
    button.TextSize = 11
    button.Font = Enum.Font.GothamSemibold
    button.AutoButtonColor = false
    button.Parent = parent
    button.ZIndex = 52

    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 10)
    buttonCorner.Parent = button

    button.MouseButton1Click:Connect(callback)

    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(70, 130, 255),
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
    end)

    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(235, 235, 245),
            TextColor3 = Color3.fromRGB(80, 80, 100)
        }):Play()
    end)

    return button
end

-- Functions
local function showLoadingAnimation(scriptName)
    loadingText.Text = "Loading " .. scriptName .. "..."
    loadingFrame.Visible = true

    spawn(function()
        while loadingFrame.Visible do
            loadingSpinner.Rotation = loadingSpinner.Rotation + 5
            wait()
        end
    end)

    wait(2)
    loadingFrame.Visible = false
end

