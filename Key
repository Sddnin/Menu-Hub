-- Island drag
island.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragIsland=true; didDrag=false
        dragStart=inp.Position; dragStartPos=islandCont.Position
    end
end)
island.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then isDragIsland=false end
end)
UIS.InputChanged:Connect(function(inp)
    if isDragIsland and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local d = inp.Position - dragStart
        if d.Magnitude > 4 then
            didDrag = true
            local vp = workspace.CurrentCamera.ViewportSize
            local nx = dragStartPos.X.Offset + d.X
            local ny = dragStartPos.Y.Offset + d.Y
            islandCont.Position = UDim2.new(0, math.clamp(nx,0,vp.X-130), 0, math.clamp(ny,0,vp.Y-34))
        end
    end
end)

