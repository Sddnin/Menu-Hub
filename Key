local function switchTab(name)
    curTab=name
    for n,b in pairs(tabBtns) do
        tw(b,0.15,{BackgroundColor3=n==name and acc() or bg3(), TextColor3=n==name and Color3.fromRGB(255,255,255) or tx2()})
    end
    home.Visible  = name=="Home"
