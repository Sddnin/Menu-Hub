local function openPanel()
    if isOpen then return end
    if didDrag then didDrag=false; return end
    isOpen=true; islandCont.Visible=false
    local ap=islandCont.AbsolutePosition
    panel.Size=UDim2.new(0,130,0,34)
    panel.Position=UDim2.new(0,ap.X,0,ap.Y)
    panel.Visible=true
    Tween:Create(panel,TweenInfo.new(0.35,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),
        {Size=UDim2.new(0,320,0,300),Position=UDim2.new(0.5,-160,0,18)}):Play()
end

local function closePanel()
    if not isOpen then return end
    isOpen=false; pfFrame.Visible=false; popup.Visible=false
    stopRoute()
    local ip=islandCont.Position
    local t=Tween:Create(panel,TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In),
        {Size=UDim2.new(0,130,0,34),Position=ip})
    t:Play(); t.Completed:Connect(function() panel.Visible=false; islandCont.Visible=true end)
end

