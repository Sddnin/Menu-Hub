-- Auto-reconnect toggle state
local autoReconnect = false
local reconnConn = nil

local function setAutoReconnect(state)
    autoReconnect = state
    if state then
        reconnBtn.Text = "🔌 Auto ON"
        tw(reconnBtn, 0.15, {BackgroundColor3 = Color3.fromRGB(40,160,80)})
        -- Watch for disconnect
        reconnConn = game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(tpState)
            if tpState == Enum.TeleportState.Failed then
                task.wait(2)
                pcall(function()
                    game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
                end)
            end
        end)
        -- Also handle kick/disconnect via game close signal
        game:BindToClose(function()
            if autoReconnect then
                pcall(function()
                    game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
                end)
            end
        end)
    else
        reconnBtn.Text = "🔌 Reconnect"
        tw(reconnBtn, 0.15, {BackgroundColor3 = isDark and Color3.fromRGB(38,80,160) or Color3.fromRGB(175,190,235)})
        if reconnConn then reconnConn:Disconnect(); reconnConn = nil end
    end
end

reconnBtn.MouseButton1Click:Connect(function()
    setAutoReconnect(not autoReconnect)
end)

