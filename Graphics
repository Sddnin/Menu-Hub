-- PERFORMANCE FUNCTIONS

local function doSmart()
    statusLabel.Text = "🧠 Smart Active"
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)

    local level = fps < 20 and 3 or fps < 35 and 2 or 1

    Lighting.GlobalShadows = false
    Lighting.Technology = level >= 2 and Enum.Technology.Compatibility or Enum.Technology.ShadowMap

    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        pcall(function()
            if obj:IsA("ParticleEmitter") then
                obj.Rate = math.min(obj.Rate, level == 3 and 5 or level == 2 and 15 or 25)
            elseif obj:IsA("MeshPart") then
                obj.RenderFidelity = Enum.RenderFidelity.Performance
            elseif obj:IsA("BasePart") then
                obj.CastShadow = false
            end
        end)
    end

    if level == 3 then clearEffects() end

    notify("🧠 SMART MODE L" .. level .. " ON!", Color3.fromRGB(220, 170, 0))
end

local function doExtreme()
    statusLabel.Text = "🚀 Extreme Active"
    statusLabel.TextColor3 = Color3.fromRGB(255, 69, 0)
    clearEffects()

    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.GlobalShadows = false
    Lighting.ShadowSoftness = 0
    Lighting.Brightness = 1.5
    Lighting.Ambient = Color3.fromRGB(190, 190, 190)
    Lighting.OutdoorAmbient = Color3.fromRGB(190, 190, 190)
    Lighting.ExposureCompensation = 0

    local count = 0
    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        pcall(function()
            if obj:IsA("BasePart") then
                obj.Material = Enum.Material.SmoothPlastic
                obj.CastShadow = false
                count += 1
            elseif obj:IsA("MeshPart") then
                obj.RenderFidelity = Enum.RenderFidelity.Performance
                obj.TextureID = ""
                count += 1
            elseif obj:IsA("ParticleEmitter") then
                obj.Rate = math.min(obj.Rate, 4)
                count += 1
            elseif obj:IsA("Fire") or obj:IsA("Smoke") then
                obj.Enabled = false
                count += 1
            end
        end)
    end

    for i = 1, 10 do
        task.wait(0.05)
        pcall(function() collectgarbage("collect") end)
    end

    notify("🚀 EXTREME: " .. count .. " optimized!", Color3.fromRGB(220, 60, 0))
end

local function doAntiLag()
    statusLabel.Text = "🛡️ Anti-Lag Active"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)

    local destroyed, optimized = 0, 0

    for _, obj in ipairs(game:GetService("Workspace"):GetDescendants()) do
        pcall(function()
            if obj:IsA("ParticleEmitter") then
                if obj.Rate > 60 then
                    obj:Destroy(); destroyed += 1
                elseif obj.Rate > 20 then
                    obj.Rate = 8; optimized += 1
                end
            elseif obj:IsA("Fire") or obj:IsA("Smoke") then
                if obj.Size > 5 then obj:Destroy(); destroyed += 1 end
            elseif obj:IsA("Sound") then
                if obj.Volume > 0.7 and not obj.Playing then
                    obj.Volume = 0.2; optimized += 1
                end
            elseif obj:IsA("BasePart") then
                obj.CastShadow = false; optimized += 1
            end
        end)
    end

    Lighting.GlobalShadows = false

    for i = 1, 15 do
        task.wait(0.04)
        pcall(function() collectgarbage("collect") end)
    end

    pcall(function()
        SoundService.AmbientReverb = Enum.ReverbType.NoReverb
    end)

    local total = destroyed + optimized
    notify("🛡️ ANTI-LAG: " .. total .. " fixed!", Color3.fromRGB(0, 200, 80))
    task.delay(1, function() notify("🗑️ Destroyed: " .. destroyed .. " | Optimized: " .. optimized, Color3.fromRGB(255, 100, 0), 3) end)
end

