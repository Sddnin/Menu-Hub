local function antiLagMode()
    statusLabel.Text = "⚡ ANTI-LAG 4X MAX"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    local lagSources = 0
    local optimized = 0
    local destroyed = 0
    
    -- 4X MORE AGGRESSIVE LAG ELIMINATION
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") then
            if not obj:IsDescendantOf(player) then
                if obj.Name:lower():find("lag") or obj.Name:lower():find("spam") or 
                   obj.Name:lower():find("loop") or obj.Name:lower():find("while") or
                   obj.Name:lower():find("wait") then
                    obj.Disabled = true
                    lagSources = lagSources + 1
                end
            end
        elseif obj:IsA("ParticleEmitter") then
            if obj.Rate > 50 then  -- Was 100, now 4X more sensitive
                obj:Destroy()
                destroyed = destroyed + 1
            elseif obj.Rate > 15 then  -- Was 30, more aggressive
                obj.Rate = 5
                obj.Lifetime = NumberRange.new(0.3, 0.7)
                obj.Speed = NumberRange.new(1, 3)
                optimized = optimized + 1
            end
        elseif obj:IsA("Fire") then
            if obj.Size > 8 then
                obj:Destroy()
                destroyed = destroyed + 1
            elseif obj.Size > 2 then
                obj.Size = 1
                optimized = optimized + 1
            end
        elseif obj:IsA("Smoke") then
            if obj.Size > 5 then
                obj:Destroy()
                destroyed = destroyed + 1
            elseif obj.Size > 1 then
                obj.Size = 0.5
                optimized = optimized + 1
            end
        elseif obj:IsA("Explosion") or obj:IsA("Beam") or obj:IsA("Trail") then
            obj.Enabled = false
            destroyed = destroyed + 1
        elseif obj:IsA("Sound") then
            if obj.Volume > 0.5 and not obj.Playing and not obj:IsDescendantOf(player.Character or {}) then
                obj:Destroy()
                destroyed = destroyed + 1
            elseif obj.Volume > 0.3 and not obj.Playing then
                obj.Volume = 0.1
                optimized = optimized + 1
            end
        elseif obj:IsA("BasePart") then
            if obj.CastShadow then
                obj.CastShadow = false
                optimized = optimized + 1
            end
        end
    end
    
    Lighting.GlobalShadows = false
    Lighting.ShadowSoftness = 0
    
    for _, e in pairs(Lighting:GetChildren()) do
        if e:IsA("BloomEffect") and e.Intensity > 1.0 then
            e.Intensity = 0.5
            optimized = optimized + 1
        elseif e:IsA("DepthOfFieldEffect") or e:IsA("SunRaysEffect") then
            e:Destroy()
            destroyed = destroyed + 1
        end
    end
    
    -- 4X MORE MEMORY CLEANUP
    for i = 1, 30 do  -- Was 8, now 30
        task.wait(0.03)
        pcall(function() 
            collectgarbage("collect")
            collectgarbage("stop")
            collectgarbage("restart")
        end)
    end
    
    pcall(function()
        SoundService.AmbientReverb = Enum.ReverbType.NoReverb
        SoundService.DistanceFactor = 20
        SoundService.DopplerScale = 0
        SoundService.RolloffScale = 0.5
    end)
    
    local total = lagSources + optimized + destroyed
    showNotification("🛡️ ANTI-LAG: " .. total .. " FIXES - 4X POWER!", Color3.fromRGB(0, 255, 100), 5)
    
    task.spawn(function()
        task.wait(1)
        showNotification("🗑️ " .. destroyed .. " items destroyed", Color3.fromRGB(255, 69, 0), 3)
        task.wait(0.8)
        showNotification("⚡ " .. optimized .. " items optimized", Color3.fromRGB(255, 140, 0), 3)
        task.wait(0.8)
        showNotification("🚫 " .. lagSources .. " scripts disabled", Color3.fromRGB(255, 0, 100), 3)
    end)
end

