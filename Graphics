    Lighting.Ambient=Color3.fromRGB(190,190,190);Lighting.OutdoorAmbient=Color3.fromRGB(190,190,190);Lighting.FogEnd=100000
    for _,o in ipairs(Workspace:GetDescendants()) do pcall(function()
        if o:IsA("BasePart") then o.Material=Enum.Material.SmoothPlastic;o.CastShadow=false;o.TopSurface=Enum.SurfaceType.Smooth;o.BottomSurface=Enum.SurfaceType.Smooth
        elseif o:IsA("MeshPart") then o.RenderFidelity=Enum.RenderFidelity.Performance;o.TextureID=""
        elseif o:IsA("UnionOperation") then o.UsePartColor=true;o.RenderFidelity=Enum.RenderFidelity.Performance
        elseif o:IsA("ParticleEmitter") then o.Rate=math.min(o.Rate,4);o.Lifetime=NumberRange.new(0.2,0.5)
        elseif o:IsA("Fire") or o:IsA("Smoke") then o.Enabled=false
        elseif o:IsA("Decal") or o:IsA("Texture") then o.Transparency=1 end
    end) end
    for i=1,12 do task.wait(0.05);pcall(function() collectgarbage("collect") end) end
    pcall(function() SoundService.AmbientReverb=Enum.ReverbType.NoReverb end)
