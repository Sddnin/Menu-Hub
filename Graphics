local function doAntiLag()
    statusLbl.Text="🛡️ Anti-Lag";statusLbl.TextColor3=Color3.fromRGB(0,255,100)
    for _,o in ipairs(Workspace:GetDescendants()) do pcall(function()
        if o:IsA("ParticleEmitter") then
            if o.Rate>60 then o:Destroy() elseif o.Rate>20 then o.Rate=8;o.Lifetime=NumberRange.new(0.3,0.8) end
        elseif o:IsA("Fire") then if o.Size>8 then o:Destroy() elseif o.Size>3 then o.Size=2 end
        elseif o:IsA("Smoke") then if o.Size>6 then o:Destroy() elseif o.Size>2 then o.Size=1 end
        elseif o:IsA("Explosion") then o.Visible=false
        elseif o:IsA("Beam") or o:IsA("Trail") then o.Enabled=false
        elseif o:IsA("Sound") then if o.Volume>0.7 and not o.Playing then o.Volume=0.2 end
        elseif o:IsA("BasePart") then o.CastShadow=false
        elseif o:IsA("MeshPart") then o.RenderFidelity=Enum.RenderFidelity.Performance end
    end) end
    Lighting.GlobalShadows=false;Lighting.ShadowSoftness=0
    for _,e in ipairs(Lighting:GetChildren()) do pcall(function()
        if e:IsA("DepthOfFieldEffect") then e:Destroy()
        elseif e:IsA("BloomEffect") and e.Intensity>1 then e.Intensity=0.5
        elseif e:IsA("SunRaysEffect") and e.Intensity>0.3 then e.Intensity=0.15 end
    end) end
    for i=1,18 do task.wait(0.04);pcall(function() collectgarbage("collect") end) end
    pcall(function() SoundService.AmbientReverb=Enum.ReverbType.NoReverb;SoundService.DopplerScale=0 end)
end
