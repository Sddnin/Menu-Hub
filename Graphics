local function doSmart()
    statusLbl.Text="🧠 Smart";statusLbl.TextColor3=Color3.fromRGB(255,200,0)
    local lv=fps<20 and 3 or fps<35 and 2 or 1
    Lighting.GlobalShadows=false
    Lighting.Technology=lv>=2 and Enum.Technology.Compatibility or Enum.Technology.ShadowMap
    for _,o in ipairs(Workspace:GetDescendants()) do pcall(function()
        if o:IsA("ParticleEmitter") then o.Rate=math.min(o.Rate,lv==3 and 5 or lv==2 and 15 or 25)
        elseif o:IsA("MeshPart") then o.RenderFidelity=Enum.RenderFidelity.Performance
        elseif o:IsA("BasePart") then o.CastShadow=false end
    end) end
    if lv==3 then clearFX() end
end
