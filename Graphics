-- Helpers
local function clearFX()
    for _,e in ipairs(Lighting:GetChildren()) do
        if e:IsA("PostEffect") then e:Destroy() end
    end
end

-- Button maker
local function mkBtn(icon,lbl,color,parent,order,fn)
    local btn = Instance.new("TextButton",parent)
    btn.BackgroundColor3 = color
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.LayoutOrder = order
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,10)
    local ig = Instance.new("TextLabel",btn)
    ig.Size = UDim2.new(1,0,0.52,0)
    ig.BackgroundTransparency = 1
    ig.Text = icon
    ig.TextColor3 = Color3.fromRGB(255,255,255)
    ig.TextScaled = true
    ig.Font = Enum.Font.GothamBold
    local lb = Instance.new("TextLabel",btn)
    lb.Size = UDim2.new(1,-4,0.45,0)
    lb.Position = UDim2.new(0,2,0.53,0)
    lb.BackgroundTransparency = 1
    lb.Text = lbl
    lb.TextColor3 = Color3.fromRGB(255,255,255)
    lb.TextScaled = true
    lb.Font = Enum.Font.GothamBold
    btn.MouseButton1Click:Connect(function() pcall(fn) end)
    return btn
end

local function mkScroll(color)
    local s = Instance.new("ScrollingFrame",content)
    s.Size = UDim2.new(1,0,1,0)
    s.BackgroundTransparency = 1
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 4
    s.ScrollBarImageColor3 = color
    s.Visible = false
    local g = Instance.new("UIGridLayout",s)
    g.CellSize = UDim2.new(0,122,0,48)
    g.CellPadding = UDim2.new(0,6,0,6)
    g.SortOrder = Enum.SortOrder.LayoutOrder
    return s,g
end

