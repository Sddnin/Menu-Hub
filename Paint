-- ============================================================
-- HISTORY SYSTEM
-- ============================================================
local function captureSnapshot()
    local snap = {}
    for li = 1, 3 do
        snap[li] = {}
        for _, child in ipairs(layers[li]:GetChildren()) do
            if child:IsA("Frame") then
                table.insert(snap[li], {
                    Size     = child.Size,
                    Position = child.Position,
                    Color    = child.BackgroundColor3,
                    Trans    = child.BackgroundTransparency,
                })
            end
        end
    end
    snap.count = S.strokeCount
    return snap
end

local function applySnapshot(snap)
    for li = 1, 3 do
        for _, child in ipairs(layers[li]:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        for _, d in ipairs(snap[li]) do
            local f = Instance.new("Frame")
            f.Size                    = d.Size
            f.Position                = d.Position
            f.BackgroundColor3        = d.Color
            f.BackgroundTransparency  = d.Trans
            f.BorderSizePixel         = 0
            f.ZIndex                  = 5 + li
            f.Parent                  = layers[li]
            corner(f, 999)
        end
    end
    S.strokeCount = snap.count
    strokeCounter.Text = snap.count .. " strokes"
end

local function pushHistory()
    -- Trim redo branch
    for i = S.histIdx + 1, #S.history do
        S.history[i] = nil
    end
    table.insert(S.history, captureSnapshot())
    S.histIdx = #S.history
    if #S.history > MAX_HISTORY then
        table.remove(S.history, 1)
        S.histIdx = S.histIdx - 1
    end
end

-- ============================================================
-- DRAWING ENGINE
-- ============================================================
local function inCanvas(pos)
    local p = canvasFrame.AbsolutePosition
    local sz = canvasFrame.AbsoluteSize
    return pos.X >= p.X and pos.X <= p.X + sz.X
        and pos.Y >= p.Y and pos.Y <= p.Y + sz.Y
end

local function toCanvas(pos)
    local p = canvasFrame.AbsolutePosition
    return Vector2.new(pos.X - p.X, pos.Y - p.Y)
end

local function spawnDot(layer, cx, cy, r, color, trans)
    local f = Instance.new("Frame")
    f.Size                   = UDim2.new(0, r*2, 0, r*2)
    f.Position               = UDim2.new(0, cx - r, 0, cy - r)
    f.BackgroundColor3       = color
    f.BackgroundTransparency = trans
    f.BorderSizePixel        = 0
    f.ZIndex                 = 5 + layer
    f.Parent                 = layers[layer]
    corner(f, 999)
end

local function interpolateDots(layer, from, to, color, r, trans)
    -- Fill gaps between last and current position for smooth lines
    local dx = to.X - from.X
    local dy = to.Y - from.Y
    local dist = math.sqrt(dx*dx + dy*dy)
    local steps = math.max(1, math.floor(dist / math.max(1, r * 0.4)))
    for i = 0, steps do
        local t = i / steps
        local cx = from.X + dx * t
        local cy = from.Y + dy * t
        spawnDot(layer, cx, cy, r, color, trans)
    end
end

local function drawAt(pos)
    if not inCanvas(pos) then return end
    local cp    = toCanvas(pos)
    local layer = S.activeLayer
    local color = S.color
    local trans = 1 - S.opacity
    local r     = S.size / 2

    if S.tool == "brush" then
        if S.lastPos then
            interpolateDots(layer, S.lastPos, cp, color, r, trans)
        else
            spawnDot(layer, cp.X, cp.Y, r, color, trans)
        end

    elseif S.tool == "pencil" then
        local pr = math.max(1, r * 0.5)
        if S.lastPos then
            interpolateDots(layer, S.lastPos, cp, color, pr, trans)
        else
            spawnDot(layer, cp.X, cp.Y, pr, color, trans)
        end

    elseif S.tool == "marker" then
        local mr = r * 1.6
        local mt = math.min(1, trans + 0.35)
        if S.lastPos then
            interpolateDots(layer, S.lastPos, cp, color, mr, mt)
        else
            spawnDot(layer, cp.X, cp.Y, mr, color, mt)
        end

    elseif S.tool == "spray" then
        for _ = 1, SPRAY_PARTICLES do
            local ox  = math.random(-S.size, S.size)
            local oy  = math.random(-S.size, S.size)
            local sr  = math.random(1, math.max(2, math.floor(r*0.5)))
            local sT  = math.random(40, 80) / 100
            spawnDot(layer, cp.X + ox, cp.Y + oy, sr, color, sT)
        end

    elseif S.tool == "eraser" then
        local er = r * 1.2
        if S.lastPos then
            interpolateDots(layer, S.lastPos, cp, T.white, er, 0)
        else
            spawnDot(layer, cp.X, cp.Y, er, T.white, 0)
        end

    elseif S.tool == "fill" then
        local fill = Instance.new("Frame")
        fill.Size                   = UDim2.new(1,0,1,0)
        fill.BackgroundColor3       = color
        fill.BackgroundTransparency = trans
        fill.BorderSizePixel        = 0
        fill.ZIndex                 = 5 + layer
        fill.Parent                 = layers[layer]
        S.strokeCount += 1
        return true -- single action, signal stop
    end

    S.lastPos = cp
    S.strokeCount += 1
    strokeCounter.Text = S.strokeCount .. " strokes"
end

-- Line tool state
local lineStart = nil
local linePreview = nil

-- ============================================================
-- INPUT HANDLERS
-- ============================================================
local function inputPos(inp)
    return inp.Position
end

local function beginDraw(pos)
    if not inCanvas(pos) then return false end
    S.drawing = true
    S.lastPos = nil

    if S.tool == "line" then
        lineStart = toCanvas(pos)
        -- create preview
        linePreview = Instance.new("Frame")
        linePreview.BackgroundColor3 = S.color
        linePreview.BackgroundTransparency = 1 - S.opacity
        linePreview.BorderSizePixel  = 0
        linePreview.ZIndex           = 18
        linePreview.Size             = UDim2.new(0, S.size, 0, S.size)
        linePreview.Parent           = canvasFrame
        corner(linePreview, 999)
    else
        drawAt(pos)
    end
    return true
end

local function continueDraw(pos)
    if not S.drawing then return end

    if S.tool == "line" and lineStart and linePreview then
        local cp = toCanvas(pos)
        local dx = cp.X - lineStart.X
        local dy = cp.Y - lineStart.Y
        local len = math.sqrt(dx*dx + dy*dy)
        local angle = math.atan2(dy, dx)
        linePreview.Size     = UDim2.new(0, math.max(S.size, len), 0, S.size)
        linePreview.Position = UDim2.new(0, lineStart.X, 0, lineStart.Y - S.size/2)
        linePreview.Rotation = math.deg(angle)
    else
        drawAt(pos)
    end
end

local function endDraw(pos)
    if not S.drawing then return end

    if S.tool == "line" and lineStart then
        local cp = toCanvas(pos)
        local dx = cp.X - lineStart.X
        local dy = cp.Y - lineStart.Y
        local len = math.sqrt(dx*dx + dy*dy)
        local angle = math.atan2(dy, dx)
        if linePreview then
            linePreview.Size     = UDim2.new(0, math.max(S.size, len), 0, S.size)
            linePreview.Position = UDim2.new(0, lineStart.X, 0, lineStart.Y - S.size/2)
            linePreview.Rotation = math.deg(angle)
            linePreview.ZIndex   = 5 + S.activeLayer
            linePreview.Parent   = layers[S.activeLayer]
            linePreview = nil
        end
        lineStart = nil
        S.strokeCount += 1
    end

    S.drawing  = false
    S.lastPos  = nil
    pushHistory()
    setStatus("💾 Saved • " .. S.strokeCount .. " strokes", T.ok)
    task.delay(2, function()
        setStatus("✨ Drawing Studio v4.0 Professional  •  Ready", T.txt2)
    end)
end

-- Mouse
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        beginDraw(inp.Position)
    elseif inp.UserInputType == Enum.UserInputType.Touch then
        beginDraw(inp.Position)
    end
end)

UserInputService.InputChanged:Connect(function(inp, gp)
    if inp.UserInputType == Enum.UserInputType.MouseMovement then
        local cp = inp.Position
        -- Move cursor preview
        if inCanvas(cp) then
            cursorDot.Visible          = true
            cursorDot.Size             = UDim2.new(0, S.size, 0, S.size)
            cursorDot.BackgroundColor3 = S.color
            local rel = toCanvas(cp)
            cursorDot.Position = UDim2.new(0, rel.X - S.size/2, 0, rel.Y - S.size/2)
        else
            cursorDot.Visible = false
        end

        if not gp then continueDraw(cp) end
    end

    if inp.UserInputType == Enum.UserInputType.Touch and not gp then
        continueDraw(inp.Position)
    end
end)

UserInputService.InputEnded:Connect(function(inp, gp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        endDraw(inp.Position)
    end
end)

-- Keyboard shortcuts
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end

    local k = inp.KeyCode
    local ctrl = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
        or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)

    if ctrl and k == Enum.KeyCode.Z then
        -- Undo
        actBtns.undo:GetPropertyChangedSignal("BackgroundColor3"):Wait()
        -- direct call
        if S.histIdx > 1 then
            S.histIdx -= 1
            applySnapshot(S.history[S.histIdx])
            setStatus("↩ Undo  (" .. S.histIdx .. "/" .. #S.history .. ")", T.warn)
        end

    elseif ctrl and k == Enum.KeyCode.Y then
        if S.histIdx < #S.history then
            S.histIdx += 1
            applySnapshot(S.history[S.histIdx])
            setStatus("↪ Redo  (" .. S.histIdx .. "/" .. #S.history .. ")", T.ok)
        end

    elseif k == Enum.KeyCode.B then S.tool = "brush";   refreshHint()
    elseif k == Enum.KeyCode.P then S.tool = "pencil";  refreshHint()
    elseif k == Enum.KeyCode.E then S.tool = "eraser";  refreshHint()
    elseif k == Enum.KeyCode.F then S.tool = "fill";    refreshHint()
    elseif k == Enum.KeyCode.L then S.tool = "line";    refreshHint()
    elseif k == Enum.KeyCode.LeftBracket then
        S.size = math.max(1, S.size - 2)
        sizeFill.Size = UDim2.new(S.size/60,0,1,0)
        sizeVal.Text  = S.size .. "px"
        refreshHint()
    elseif k == Enum.KeyCode.RightBracket then
        S.size = math.min(60, S.size + 2)
        sizeFill.Size = UDim2.new(S.size/60,0,1,0)
        sizeVal.Text  = S.size .. "px"
        refreshHint()
    end

    -- Update tool selection highlight
    for id, btn in pairs(toolBtns) do
        tween(btn, {
            BackgroundColor3       = id == S.tool and T.acc or T.bg2,
            BackgroundTransparency = id == S.tool and 0 or 0.2
        }, 0.2)
    end
end)

