-- ==================== TAB SWITCHING ====================
local function switchTab(name)
    currentTab = name
    for n,d in pairs(tabButtons) do
        if n==name then
            TweenService:Create(d.button,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,60,200),TextColor3=Color3.fromRGB(255,255,255)}):Play()
        else
            TweenService:Create(d.button,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(30,30,42),TextColor3=Color3.fromRGB(140,140,160)}):Play()
        end
    end
    homeContent.Visible = name=="Home"
    otherContent.Visible = name=="Other"
end

for name,d in pairs(tabButtons) do
    d.button.MouseButton1Click:Connect(function() switchTab(name) end)
end

-- ==================== EXPAND / COLLAPSE ====================
local function expandIsland()
    if isExpanded then return end
    isExpanded = true
    -- Snap panel to center regardless of where island was dragged
    local islandAbsPos = islandContainer.AbsolutePosition
    islandContainer.Visible = false
    expandedPanel.Size = UDim2.new(0,120,0,37)
    expandedPanel.Position = UDim2.new(0, islandAbsPos.X, 0, islandAbsPos.Y)
    expandedPanel.Visible = true
    TweenService:Create(expandedPanel, TweenInfo.new(0.4,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),
        {Size=UDim2.new(0,380,0,360), Position=UDim2.new(0.5,-190,0,20)}):Play()
end

local function collapseIsland()
    if not isExpanded then return end
    isExpanded = false
    playerFrame.Visible = false
    popup.Visible = false
    local islandPos = islandContainer.Position
    local t = TweenService:Create(expandedPanel, TweenInfo.new(0.3,Enum.EasingStyle.Quart,Enum.EasingDirection.In),
        {Size=UDim2.new(0,120,0,37), Position=islandPos})
    t:Play()
    t.Completed:Connect(function()
        expandedPanel.Visible = false
        islandContainer.Visible = true
    end)
end

closeBtn.MouseButton1Click:Connect(collapseIsland)
dynamicIsland.MouseButton1Click:Connect(expandIsland)

UserInputService.InputBegan:Connect(function(inp,proc)
    if proc then return end
    if inp.KeyCode==Enum.KeyCode.RightShift then
        if isExpanded then collapseIsland() else expandIsland() end
    end
end)

