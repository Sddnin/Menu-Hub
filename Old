local function updatePlayerList(searchTerm)
    searchTerm = (searchTerm or ""):lower()
    for _, child in pairs(playerList:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local count = 0
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            if searchTerm == "" or targetPlayer.Name:lower():find(searchTerm) then
                local pContainer = Instance.new("Frame")
                pContainer.Size = UDim2.new(1, 0, 0, 62)
                pContainer.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
                pContainer.BorderSizePixel = 0
                pContainer.Parent = playerList
                pContainer.ZIndex = 62

                local pcCorner = Instance.new("UICorner")
                pcCorner.CornerRadius = UDim.new(0, 7)
                pcCorner.Parent = pContainer

                local pName = Instance.new("TextLabel")
                pName.Size = UDim2.new(1, -10, 0, 16)
                pName.Position = UDim2.new(0, 5, 0, 3)
                pName.BackgroundTransparency = 1
                pName.Text = targetPlayer.Name
                pName.TextSize = 10
                pName.Font = Enum.Font.GothamBold
                pName.TextColor3 = Color3.fromRGB(200, 200, 240)
                pName.TextXAlignment = Enum.TextXAlignment.Left
                pName.Parent = pContainer
                pName.ZIndex = 63

                local function makeSmallBtn(txt, xPos, yPos, color)
                    local b = Instance.new("TextButton")
                    b.Size = UDim2.new(0, 50, 0, 18)
                    b.Position = UDim2.new(0, xPos, 0, yPos)
                    b.BackgroundColor3 = color
                    b.Text = txt
                    b.TextSize = 9
                    b.Font = Enum.Font.GothamBold
                    b.TextColor3 = Color3.fromRGB(255, 255, 255)
                    b.AutoButtonColor = false
                    b.BorderSizePixel = 0
                    b.Parent = pContainer
                    b.ZIndex = 63
                    local bc = Instance.new("UICorner")
                    bc.CornerRadius = UDim.new(0, 5)
                    bc.Parent = b
                    return b
                end

                local tpBtn = makeSmallBtn("TP", 5, 22, Color3.fromRGB(50, 100, 200))
                local viewBtn = makeSmallBtn("View", 60, 22, Color3.fromRGB(200, 120, 40))
                local watchBtn = makeSmallBtn("👁 Watch", 5, 42, Color3.fromRGB(120, 60, 200))
                local idBtn = makeSmallBtn("📋 ID", 60, 42, Color3.fromRGB(60, 160, 110))

                tpBtn.MouseButton1Click:Connect(function()
                    if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        if character and character:FindFirstChild("HumanoidRootPart") then
                            character.HumanoidRootPart.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame
                        end
                    end
                end)

                viewBtn.MouseButton1Click:Connect(function()
                    if targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid") then
                        workspace.CurrentCamera.CameraSubject = targetPlayer.Character.Humanoid
                    end
                end)

                local isWatching = false
                local watchConn
                watchBtn.MouseButton1Click:Connect(function()
                    isWatching = not isWatching
                    if isWatching then
                        watchBtn.BackgroundColor3 = Color3.fromRGB(80, 180, 80)
                        watchBtn.Text = "✓ Watch"
                        if targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid") then
                            workspace.CurrentCamera.CameraSubject = targetPlayer.Character.Humanoid
                        end
                    else
                        watchBtn.BackgroundColor3 = Color3.fromRGB(120, 60, 200)
                        watchBtn.Text = "👁 Watch"
                        if watchConn then watchConn:Disconnect(); watchConn = nil end
                        resetCamera()
                    end
                end)

                idBtn.MouseButton1Click:Connect(function()
                    setclipboard(tostring(targetPlayer.UserId))
                    idBtn.Text = "✓ Copied"
                    wait(1.5)
                    idBtn.Text = "📋 ID"
                end)

                count = count + 1
            end
        end
    end
    playerList.CanvasSize = UDim2.new(0, 0, 0, count * 65)
end

