local function applyTheme()
    local dark = isDarkTheme

    -- Panel background + gradient
    expandedPanel.BackgroundColor3 = dark and Color3.fromRGB(15,15,20) or Color3.fromRGB(245,245,252)
    panelGradient.Color = dark and
        ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(22,22,30)),ColorSequenceKeypoint.new(1,Color3.fromRGB(12,12,18))} or
        ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(250,250,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(235,235,248))}
    panelStroke.Color = dark and Color3.fromRGB(50,40,100) or Color3.fromRGB(190,185,220)

    -- Header
    header.TextColor3 = dark and Color3.fromRGB(180,180,255) or Color3.fromRGB(55,45,115)
    header.BackgroundTransparency = 1

    -- Close button (always red, fine as is)

    -- Tab frame + buttons
    tabFrame.BackgroundColor3 = dark and Color3.fromRGB(25,25,35) or Color3.fromRGB(220,220,238)
    for name, d in pairs(tabButtons) do
        local isActive = name == currentTab
        d.button.BackgroundColor3 = isActive and Color3.fromRGB(80,60,200) or
            (dark and Color3.fromRGB(30,30,42) or Color3.fromRGB(205,205,228))
        d.button.TextColor3 = isActive and Color3.fromRGB(255,255,255) or
            (dark and Color3.fromRGB(140,140,160) or Color3.fromRGB(80,70,130))
    end

    -- Divider
    divider.BackgroundColor3 = dark and Color3.fromRGB(45,45,65) or Color3.fromRGB(200,200,222)

    -- Section labels
    for _, lbl in pairs(homeContent:GetChildren()) do
        if lbl:IsA("TextLabel") then
            lbl.TextColor3 = dark and Color3.fromRGB(90,90,130) or Color3.fromRGB(120,110,170)
        end
    end

    -- Dynamic island
    dynamicIsland.BackgroundColor3 = dark and Color3.fromRGB(20,20,25) or Color3.fromRGB(235,235,250)
    islandText.TextColor3 = dark and Color3.fromRGB(200,200,255) or Color3.fromRGB(55,45,115)

    -- Speed / Jump labels + textboxes
    speedLabel.TextColor3 = dark and Color3.fromRGB(150,150,200) or Color3.fromRGB(80,75,140)
    jumpLabel.TextColor3  = dark and Color3.fromRGB(150,150,200) or Color3.fromRGB(80,75,140)
    speedSlider.BackgroundColor3 = dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(228,228,245)
    speedSlider.TextColor3       = dark and Color3.fromRGB(200,200,255) or Color3.fromRGB(50,45,100)
    jumpSlider.BackgroundColor3  = dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(228,228,245)
    jumpSlider.TextColor3        = dark and Color3.fromRGB(200,200,255) or Color3.fromRGB(50,45,100)

    -- Set buttons (speedApply, jumpApply stay accent blue — fine)

    -- Players + Fly + Screenshot buttons
    playersBtn.BackgroundColor3 = dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(228,228,245)
    playersBtn.TextColor3       = dark and Color3.fromRGB(170,170,220) or Color3.fromRGB(70,65,140)
    flyBtn.BackgroundColor3     = dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(228,228,245)
    flyBtn.TextColor3           = dark and Color3.fromRGB(170,170,220) or Color3.fromRGB(70,65,140)
    ssBtn.BackgroundColor3      = dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(228,228,245)
    ssBtn.TextColor3            = dark and Color3.fromRGB(170,170,220) or Color3.fromRGB(70,65,140)

    -- Reset button
    resetBtn.BackgroundColor3 = dark and Color3.fromRGB(32,24,58) or Color3.fromRGB(218,210,248)
    resetBtn.TextColor3       = dark and Color3.fromRGB(170,150,255) or Color3.fromRGB(60,40,140)

    -- Popup background + title + stroke
    popup.BackgroundColor3    = dark and Color3.fromRGB(20,20,30) or Color3.fromRGB(240,240,252)
    popupTitle.TextColor3     = dark and Color3.fromRGB(200,200,255) or Color3.fromRGB(55,45,115)
    popupStroke.Color         = dark and Color3.fromRGB(80,60,160) or Color3.fromRGB(170,160,220)
    cancelPopup.TextColor3    = dark and Color3.fromRGB(100,100,130) or Color3.fromRGB(140,130,180)
    tpHistLabel.TextColor3    = dark and Color3.fromRGB(160,160,220) or Color3.fromRGB(80,70,150)
    tpHistFrame.BackgroundColor3 = dark and Color3.fromRGB(14,14,22) or Color3.fromRGB(218,218,240)

    -- Popup buttons recolor
    resetCamBtn.BackgroundColor3 = dark and Color3.fromRGB(35,60,155)  or Color3.fromRGB(180,185,235)
    resetCamBtn.TextColor3       = dark and Color3.fromRGB(255,255,255) or Color3.fromRGB(40,40,100)
    resetAllBtn.BackgroundColor3 = dark and Color3.fromRGB(150,35,75)  or Color3.fromRGB(235,185,200)
    resetAllBtn.TextColor3       = dark and Color3.fromRGB(255,255,255) or Color3.fromRGB(100,30,55)
    darkBtn.BackgroundColor3     = dark and Color3.fromRGB(28,28,45)   or Color3.fromRGB(55,50,80)
    darkBtn.TextColor3           = Color3.fromRGB(220,220,255)
    lightBtn.BackgroundColor3    = dark and Color3.fromRGB(200,195,230) or Color3.fromRGB(255,252,230)
    lightBtn.TextColor3          = dark and Color3.fromRGB(50,40,100)  or Color3.fromRGB(80,70,30)

    -- Player frame + internals
    playerFrame.BackgroundColor3    = dark and Color3.fromRGB(18,18,26) or Color3.fromRGB(235,235,250)
    pfStroke.Color                  = dark and Color3.fromRGB(55,50,100) or Color3.fromRGB(180,175,220)
    playerTitle.TextColor3          = dark and Color3.fromRGB(180,180,240) or Color3.fromRGB(60,50,120)
    playerSearchBox.BackgroundColor3= dark and Color3.fromRGB(28,28,42) or Color3.fromRGB(220,220,240)
    playerSearchBox.TextColor3      = dark and Color3.fromRGB(180,180,220) or Color3.fromRGB(60,55,120)
    playerList.BackgroundColor3     = dark and Color3.fromRGB(22,22,32) or Color3.fromRGB(225,225,242)

    -- Re-tint toggle rows
    for name, _ in pairs(toggleStates) do
        local row = homeContent:FindFirstChild(name.."Row")
        if row then
            local isOn = toggleStates[name]
            local track = row:FindFirstChild("Track")
            local lbl = row:FindFirstChildWhichIsA("TextLabel")
            if dark then
                row.BackgroundColor3 = isOn and Color3.fromRGB(28,22,55) or Color3.fromRGB(24,24,36)
                if track then track.BackgroundColor3 = isOn and Color3.fromRGB(80,60,200) or Color3.fromRGB(55,55,75) end
                if lbl then lbl.TextColor3 = Color3.fromRGB(170,170,210) end
            else
                row.BackgroundColor3 = isOn and Color3.fromRGB(218,212,248) or Color3.fromRGB(232,232,248)
                if track then track.BackgroundColor3 = isOn and Color3.fromRGB(80,60,200) or Color3.fromRGB(185,185,210) end
                if lbl then lbl.TextColor3 = Color3.fromRGB(70,60,130) end
            end
        end
    end
end

