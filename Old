-- ==================== ISLAND DRAG ====================
local isDraggingIsland = false
local islandDragStart, islandStartPos

dynamicIsland.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingIsland = true
        islandDragStart = input.Position
        islandStartPos = islandContainer.Position
    end
end)

dynamicIsland.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingIsland = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDraggingIsland and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - islandDragStart
        local vp = workspace.CurrentCamera.ViewportSize
        local newX = islandStartPos.X.Scale * vp.X + islandStartPos.X.Offset + delta.X
        local newY = islandStartPos.Y.Scale * vp.Y + islandStartPos.Y.Offset + delta.Y
        -- Clamp inside screen
        newX = math.clamp(newX, 0, vp.X - 120)
        newY = math.clamp(newY, 0, vp.Y - 37)
        islandContainer.Position = UDim2.new(0, newX, 0, newY)
    end
end)

