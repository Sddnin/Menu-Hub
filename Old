local function switchTab(tabName)
    currentTab = tabName
    for name, tabData in pairs(tabButtons) do
        if name == tabName then
            TweenService:Create(tabData.button, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(80, 60, 200),
                TextColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        else
            TweenService:Create(tabData.button, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(30, 30, 42),
                TextColor3 = Color3.fromRGB(140, 140, 160)
            }):Play()
        end
    end
    homeContent.Visible = tabName == "Home"
    otherContent.Visible = tabName == "Other"
end

for tabName, tabData in pairs(tabButtons) do
    tabData.button.MouseButton1Click:Connect(function()
        switchTab(tabName)
    end)
end

-- ==================== EXPAND / COLLAPSE ====================
local function expandIsland()
    if isExpanded then return end
    isExpanded = true
    islandContainer.Visible = false

    expandedPanel.Size = UDim2.new(0, 120, 0, 37)
    expandedPanel.Position = UDim2.new(0.5, -60, 0, 10)
    expandedPanel.Visible = true

    TweenService:Create(expandedPanel,
        TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 380, 0, 340), Position = UDim2.new(0.5, -190, 0, 20)}
    ):Play()
end

local function collapseIsland()
    if not isExpanded then return end
    isExpanded = false
    playerFrame.Visible = false
    resetPopup.Visible = false

    local t = TweenService:Create(expandedPanel,
        TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
        {Size = UDim2.new(0, 120, 0, 37), Position = UDim2.new(0.5, -60, 0, 10)}
    )
    t:Play()
    t.Completed:Connect(function()
        expandedPanel.Visible = false
        islandContainer.Visible = true
    end)
end

closeBtn.MouseButton1Click:Connect(collapseIsland)
dynamicIsland.MouseButton1Click:Connect(expandIsland)

-- Keyboard shortcut
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if isExpanded then collapseIsland() else expandIsland() end
    end
end)

