-- ==================== iOS TOGGLE SWITCH ====================
local toggleStates = {}
local toggleSetters = {}  -- store setter functions for reset

local function createToggleSwitch(name, icon, labelText, yPos, onToggle)
    local row = Instance.new("Frame")
    row.Name = name.."Row"
    row.Size = UDim2.new(0.46, 0, 0, 40)
    row.Position = UDim2.new(0, 0, 0, yPos)
    row.BackgroundColor3 = Color3.fromRGB(24, 24, 36)
    row.BorderSizePixel = 0
    row.Parent = homeContent
    row.ZIndex = 52
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(0, 28, 1, 0)
    iconLbl.Position = UDim2.new(0, 4, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icon
    iconLbl.TextSize = 16
    iconLbl.Font = Enum.Font.Gotham
    iconLbl.Parent = row
    iconLbl.ZIndex = 53

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -82, 1, 0)
    lbl.Position = UDim2.new(0, 32, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(170, 170, 210)
    lbl.TextSize = 10
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row
    lbl.ZIndex = 53

    -- Track (pill background)
    local track = Instance.new("Frame")
    track.Name = "Track"
    track.Size = UDim2.new(0, 38, 0, 22)
    track.Position = UDim2.new(1, -44, 0.5, -11)
    track.BackgroundColor3 = Color3.fromRGB(55, 55, 75)
    track.BorderSizePixel = 0
    track.Parent = row
    track.ZIndex = 54
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    -- Thumb (white circle)
    local thumb = Instance.new("Frame")
    thumb.Name = "Thumb"
    thumb.Size = UDim2.new(0, 16, 0, 16)
    thumb.Position = UDim2.new(0, 3, 0.5, -8)  -- OFF = left
    thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    thumb.BorderSizePixel = 0
    thumb.Parent = track
    thumb.ZIndex = 55
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    -- Shadow on thumb
    local thumbShadow = Instance.new("UIStroke")
    thumbShadow.Color = Color3.fromRGB(0,0,0)
    thumbShadow.Thickness = 0.5
    thumbShadow.Transparency = 0.7
    thumbShadow.Parent = thumb

    local clickBtn = Instance.new("TextButton")
    clickBtn.Size = UDim2.new(1, 0, 1, 0)
    clickBtn.BackgroundTransparency = 1
    clickBtn.Text = ""
    clickBtn.AutoButtonColor = false
    clickBtn.Parent = row
    clickBtn.ZIndex = 56

    local isOn = false
    toggleStates[name] = false

    local function setToggle(state)
        isOn = state
        toggleStates[name] = state

        if isOn then
            TweenService:Create(track, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(80, 60, 200)
            }):Play()
            -- Slide right: track width=38, thumb width=16, right padding=3 → pos = 38-16-3 = 19
            TweenService:Create(thumb, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
                Position = UDim2.new(0, 19, 0.5, -8)
            }):Play()
            TweenService:Create(row, TweenInfo.new(0.18), {
                BackgroundColor3 = Color3.fromRGB(28, 22, 55)
            }):Play()
        else
            TweenService:Create(track, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(55, 55, 75)
            }):Play()
            TweenService:Create(thumb, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
                Position = UDim2.new(0, 3, 0.5, -8)
            }):Play()
            TweenService:Create(row, TweenInfo.new(0.18), {
                BackgroundColor3 = Color3.fromRGB(24, 24, 36)
            }):Play()
        end

        pcall(onToggle, isOn)
    end

    clickBtn.MouseButton1Click:Connect(function()
        setToggle(not isOn)
    end)

    toggleSetters[name] = setToggle
    return row, setToggle
end

-- Create 4 toggles on left side
createToggleSwitch("Noclip", "👻", "Noclip", 22, function(state)
    noclip = state
    if noclipConnection then noclipConnection:Disconnect(); noclipConnection = nil end
    if noclip then
        noclipConnection = RunService.Stepped:Connect(function()
            if character then
                for _, p in pairs(character:GetChildren()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    else
        if character then
            for _, p in pairs(character:GetChildren()) do
                if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.CanCollide = true end
            end
        end
    end
end)

createToggleSwitch("InfJump", "♾️", "Inf Jump", 68, function(state)
    infiniteJump = state
    if jumpConnection then jumpConnection:Disconnect(); jumpConnection = nil end
    if infiniteJump then
        jumpConnection = UserInputService.JumpRequest:Connect(function()
            if character and character:FindFirstChild("Humanoid") then
                character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end)

createToggleSwitch("AntiAFK", "⚡", "Anti-AFK", 114, function(state)
    antiAFK = state
    if afkConnection then afkConnection:Disconnect(); afkConnection = nil end
    if antiAFK then
        afkConnection = Players.LocalPlayer.Idled:Connect(function()
            game:GetService("VirtualUser"):CaptureController()
            game:GetService("VirtualUser"):ClickButton2(Vector2.new())
        end)
    end
end)

