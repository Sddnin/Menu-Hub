local function updatePlayerList(searchTerm)
    searchTerm = (searchTerm or ""):lower()
    for _, c in pairs(playerList:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    local count = 0
    for _, tp in pairs(Players:GetPlayers()) do
        if tp ~= player and (searchTerm=="" or tp.Name:lower():find(searchTerm)) then
            -- Card: name row + 3 buttons in one row (TP | View | ID)
            local pc = Instance.new("Frame")
            pc.Size = UDim2.new(1,0,0,46)
            pc.BackgroundColor3 = Color3.fromRGB(28,28,42)
            pc.BorderSizePixel = 0
            pc.Parent = playerList
            pc.ZIndex = 62
            Instance.new("UICorner",pc).CornerRadius = UDim.new(0,7)

            local pn = Instance.new("TextLabel")
            pn.Size = UDim2.new(1,-10,0,16)
            pn.Position = UDim2.new(0,5,0,3)
            pn.BackgroundTransparency = 1
            pn.Text = tp.Name; pn.TextSize = 10; pn.Font = Enum.Font.GothamBold
            pn.TextColor3 = Color3.fromRGB(200,200,240)
            pn.TextXAlignment = Enum.TextXAlignment.Left
            pn.Parent = pc; pn.ZIndex = 63

            -- Helper: button width fits 3 evenly in row
            local function sb(txt, xOff, col)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(0, 48, 0, 18)
                b.Position = UDim2.new(0, xOff, 0, 24)
                b.BackgroundColor3 = col
                b.Text = txt; b.TextSize = 9; b.Font = Enum.Font.GothamBold
                b.TextColor3 = Color3.fromRGB(255,255,255)
                b.AutoButtonColor = false; b.BorderSizePixel = 0
                b.Parent = pc; b.ZIndex = 63
                Instance.new("UICorner",b).CornerRadius = UDim.new(0,5)
                return b
            end

            local tpBtn   = sb("TP",     5,  Color3.fromRGB(50,100,200))
            local viewBtn = sb("View",   58, Color3.fromRGB(200,120,40))
            local idBtn   = sb("📋 ID",  111, Color3.fromRGB(60,160,110))

            tpBtn.MouseButton1Click:Connect(function()
                if tp.Character and tp.Character:FindFirstChild("HumanoidRootPart") and
                   character and character:FindFirstChild("HumanoidRootPart") then
                    -- Save current pos to history before TP
                    local currentCF = character.HumanoidRootPart.CFrame
                    local label = string.format("Before→%s (%d,%d,%d)", tp.Name,
                        math.floor(currentCF.X), math.floor(currentCF.Y), math.floor(currentCF.Z))
                    table.insert(tpHistory, {label=label, cframe=currentCF})
                    if #tpHistory > MAX_TP_HISTORY then table.remove(tpHistory,1) end
                    refreshTpHistUI()
                    character.HumanoidRootPart.CFrame = tp.Character.HumanoidRootPart.CFrame
                end
            end)
            viewBtn.MouseButton1Click:Connect(function()
                if tp.Character and tp.Character:FindFirstChild("Humanoid") then
                    workspace.CurrentCamera.CameraSubject = tp.Character.Humanoid
                end
            end)
            idBtn.MouseButton1Click:Connect(function()
                pcall(function() setclipboard(tostring(tp.UserId)) end)
                idBtn.Text="✓ OK"; wait(1.5); idBtn.Text="📋 ID"
            end)
            count = count+1
        end
    end
    playerList.CanvasSize = UDim2.new(0,0,0,count*49)
end

