-- Hàm chuyển đổi trạng thái Island (Mở/Đóng)
local function toggleIsland()
    isExpanded = not isExpanded
    
    local targetSize = isExpanded and IslandConfig.ExpandedSize or IslandConfig.CollapsedSize
    local targetRadius = isExpanded and UDim.new(0, 40) or UDim.new(1, 0) -- Khi mở to thì bo góc ít hơn chút cho đẹp
    
    -- Tween Size (Hiệu ứng nảy)
    local tweenInfo = TweenInfo.new(IslandConfig.AnimSpeed, IslandConfig.AnimStyle, IslandConfig.AnimDir)
    TweenService:Create(island, tweenInfo, {Size = targetSize}):Play()
    TweenService:Create(islandCorner, tweenInfo, {CornerRadius = targetRadius}):Play()
    
    if isExpanded then
        -- Fade Out collapsed items
        for _, child in pairs(collapsedContent:GetChildren()) do
            if child:IsA("GuiObject") then TweenService:Create(child, TweenInfo.new(0.2), {TextTransparency = 1, ImageTransparency = 1, BackgroundTransparency = 1}):Play() end
        end
        
        -- Show expanded items (Delay nhẹ để frame to ra trước)
        task.wait(0.1)
        expandedContent.Visible = true
        for _, child in pairs(expandedContent:GetChildren()) do
            if child:IsA("GuiObject") and child.Name ~= "Controls" then -- Reset transparency logic here if needed
               -- Simple visibility toggle for now for smoothness
            end
        end
        
    else
        -- Hide expanded items
        expandedContent.Visible = false
        
        -- Fade In collapsed items
        task.wait(0.2)
        for _, child in pairs(collapsedContent:GetChildren()) do
            if child:IsA("ImageLabel") then
                TweenService:Create(child, TweenInfo.new(0.3), {ImageTransparency = 0}):Play()
            elseif child:IsA("Frame") then
                TweenService:Create(child, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play() -- Viz container is trans
                for _, bar in pairs(child:GetChildren()) do
                    if bar:IsA("Frame") then bar.BackgroundTransparency = 0 end
                end
            end
        end
    end
end

