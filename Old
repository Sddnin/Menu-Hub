-- Toggle Button Creator
local function createToggleButton(name, text, yPos, onToggle)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0.46, 0, 0, 38)
    btn.Position = UDim2.new(0, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = homeContent
    btn.ZIndex = 52

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = btn

    -- Icon
    local parts = string.split(text, "|")
    local icon = parts[1] or "?"
    local label = parts[2] or text

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 32, 1, 0)
    iconLabel.Position = UDim2.new(0, 4, 0, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextSize = 18
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.Parent = btn
    iconLabel.ZIndex = 53

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -38, 1, -10)
    textLabel.Position = UDim2.new(0, 36, 0, 5)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = label
    textLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
    textLabel.TextSize = 11
    textLabel.Font = Enum.Font.GothamSemibold
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Parent = btn
    textLabel.ZIndex = 53

    -- Status dot
    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 7, 0, 7)
    dot.Position = UDim2.new(1, -12, 0, 5)
    dot.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
    dot.BorderSizePixel = 0
    dot.Parent = btn
    dot.ZIndex = 53

    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = dot

    local isOn = false

    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        pcall(onToggle, isOn)

        if isOn then
            TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(50, 30, 160)
            }):Play()
            TweenService:Create(dot, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(100, 220, 120)
            }):Play()
            TweenService:Create(textLabel, TweenInfo.new(0.2), {
                TextColor3 = Color3.fromRGB(200, 200, 255)
            }):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
                BackgroundColor3 = Color3.fromRGB(28, 28, 40)
            }):Play()
            TweenService:Create(dot, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            }):Play()
            TweenService:Create(textLabel, TweenInfo.new(0.2), {
                TextColor3 = Color3.fromRGB(180, 180, 200)
            }):Play()
        end
    end)

    btn.MouseEnter:Connect(function()
        if not isOn then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(38, 38, 55)
            }):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if not isOn then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(28, 28, 40)
            }):Play()
        end
    end)

    return btn
end

-- Noclip Toggle
createToggleButton("NoclipBtn", "👻|Noclip", 22, function(state)
    noclip = state
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    if noclip then
        noclipConnection = RunService.Stepped:Connect(function()
            if character then
                for _, part in pairs(character:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    else
        if character then
            for _, part in pairs(character:GetChildren()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end
end)

