-- Hàm cập nhật thông tin bài hát
local function updateSongInfo()
    local track = musicLibrary[currentTrackIndex]
    songTitle.Text = track.name
    sound.SoundId = "rbxassetid://" .. track.id
    statusText.Text = "Ready to play"
end

-- Hàm Play/Pause
local function togglePlay()
    if sound.IsPlaying then
        sound:Pause()
        playBtn.Text = "▶"
        statusText.Text = "Paused"
        isPlaying = false
    else
        sound:Resume()
        if sound.TimePosition == 0 then sound:Play() end
        playBtn.Text = "⏸"
        statusText.Text = "Now Playing..."
        isPlaying = true
    end
end

-- Nút điều khiển
playBtn.MouseButton1Click:Connect(togglePlay)

nextBtn.MouseButton1Click:Connect(function()
    currentTrackIndex = currentTrackIndex + 1
    if currentTrackIndex > #musicLibrary then currentTrackIndex = 1 end
    updateSongInfo()
    sound.TimePosition = 0
    sound:Play()
    playBtn.Text = "⏸"
    isPlaying = true
end)

prevBtn.MouseButton1Click:Connect(function()
    currentTrackIndex = currentTrackIndex - 1
    if currentTrackIndex < 1 then currentTrackIndex = #musicLibrary end
    updateSongInfo()
    sound.TimePosition = 0
    sound:Play()
    playBtn.Text = "⏸"
    isPlaying = true
end)

-- === VISUALIZER ANIMATION ===
RunService.RenderStepped:Connect(function()
    if isPlaying then
        -- Update Progress Bar
        if sound.TimeLength > 0 then
            local progress = sound.TimePosition / sound.TimeLength
            TweenService:Create(progressFill, TweenInfo.new(0.1), {Size = UDim2.new(progress, 0, 1, 0)}):Play()
        end
        
        -- Animate Mini Bars (Random bouncing)
        for _, bar in pairs(bars) do
            local randomHeight = math.random(30, 100) / 100
            TweenService:Create(bar, TweenInfo.new(0.1), {Size = UDim2.new(0, 4, randomHeight, 0), Position = UDim2.new(bar.Position.X.Scale, bar.Position.X.Offset, 1 - randomHeight, 0)}):Play()
        end
        
        -- Color Pulse Effect
        local hue = tick() % 5 / 5
        local color = Color3.fromHSV(hue, 0.6, 1)
        miniIcon.ImageColor3 = color
        for _, bar in pairs(bars) do bar.BackgroundColor3 = color end
    else
        -- Reset Animations when paused
        for _, bar in pairs(bars) do
            TweenService:Create(bar, TweenInfo.new(0.3), {Size = UDim2.new(0, 4, 0.2, 0), Position = UDim2.new(bar.Position.X.Scale, bar.Position.X.Offset, 0.8, 0)}):Play()
        end
    end
end)

